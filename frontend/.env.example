# Node/Express Backend
# For local dev: http://localhost:3000/api
# For production: http://<your-ip>:3000/api
VITE_NODE_BACKEND_URL=http://localhost:3000/api

# Python Backend
# For local dev: http://localhost:8000
# For production: http://<your-ip>:9000
VITE_PYTHON_BACKEND_URL=http://localhost:8000

# Python WebSocket (for face detection)
# For local dev: ws://localhost:8000
# For production: ws://<your-ip>:9000
VITE_PYTHON_WS_URL=ws://localhost:8000

